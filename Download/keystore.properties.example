# EXAMPLE keystore.properties — copy this to `keystore.properties`
# (same folder, no `.example` suffix) and fill in the four entries
# below with the values from the keystore you generated with keytool.
#
# IMPORTANT: keystore.properties is in .gitignore. Never commit it.
# If you ever lose the .jks file OR the passwords inside this file,
# you can no longer publish updates to the same Play Store listing —
# Google enforces "same upload key forever". Back up both:
#   1. lokali-release.jks            (the actual key)
#   2. keystore.properties           (the passwords to unlock it)
# to a SECURE password manager (1Password, Bitwarden), NOT iCloud /
# Google Drive notes / a desktop text file.
#
# How to generate the keystore:
#   keytool -genkey -v -keystore lokali-release.jks \
#     -alias lokali -keyalg RSA -keysize 2048 -validity 10000
# The command will prompt for store password, key password, your
# name, org, etc. Put the same store/key password into the entries
# below; the rest of the prompts (name, org) just become metadata
# inside the certificate — they don't need to match anything.

storeFile=lokali-release.jks
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=lokali
keyPassword=REPLACE_WITH_KEY_PASSWORD
