# Legacy peer dep resolution — required because @tanstack/zod-adapter
# pins its peer dependency to zod@^3.x, but the rest of the codebase
# uses zod@4.x. zod-adapter actually works fine with zod 4 — the
# upstream package just hasn't broadened its peerDependencies range.
# Lovable's deploy runs with this flag implicitly, so without an
# explicit .npmrc local `npm install` errors out where the deploy
# succeeds.
#
# Drop this flag once @tanstack/zod-adapter publishes a version
# whose peerDependencies allows zod ^4.
legacy-peer-deps=true
